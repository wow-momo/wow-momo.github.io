{
  "name": "wow-momo-website",
  "version": "1.0.0",
  "description": "WoW Mo:Mo — Authentic Nepali Momos in Manor, TX",
  "private": true,
  "scripts": {
    "serve": "npx serve -l 3000 .",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:a11y": "npx playwright test tests/accessibility.spec.js",
    "test:html": "npx html-validate *.html",
    "test:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.42.0",
    "html-validate": "^8.9.0",
    "serve": "^14.2.0"
  }
}
